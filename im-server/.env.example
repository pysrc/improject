# ====================== 服务器配置 ======================
# 服务端口
PORT=3001

# ====================== JWT 配置 ======================
# JWT 密钥（生产环境请更换为复杂随机字符串）
JWT_SECRET=im-server-secret-2026
# JWT 过期时间（如: 1d, 7d, 24h）
JWT_EXPIRES_IN=7d

# TURN 服务器地址（必须配置才能跨网络通话）
# 格式: turn:域名或IP:端口
# 示例: turn:stun.example.com:3478 或 turn:192.168.1.100:3478
TURN_URLS=turn:stun.example.com:3478

# TURN 认证密钥（与 coturn 的 --static-auth-secret 保持一致）
TURN_SECRET=CHANGE_ME_16_RANDOM_CHARS

# TURN 凭证有效期（秒），默认 1 小时
TURN_EXPIRY=3600

# ====================== 文件上传配置 ======================
# 文件上传目录（相对于 server.js 所在目录）
# UPLOAD_DIR=./uploads